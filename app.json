{
  "expo": {
    "name": "PicklePro",
    "slug": "picklepro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "picklepro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.picklepro.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.picklepro.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1A8FE3",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "PicklePro",
      "shortName": "PicklePro",
      "description": "Book pickleball courts in Lapu-Lapu City, Cebu. Find available slots, pay online, and get directions.",
      "themeColor": "#1A8FE3",
      "backgroundColor": "#ffffff",
      "lang": "en"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A8FE3",
          "dark": {
            "backgroundColor": "#1270B5"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
